(set-info :smt-lib-version 2.6)
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-fun v0 () U)
(declare-fun v1 () U)
(declare-fun v2 () U)
(declare-fun x0 () U)
(declare-fun x1 () U)
(declare-fun x2 () U)
(declare-fun x3 () U)
(declare-fun x4 () U)
(declare-fun P (U) Bool)
(assert (not (= v0 v1)))
(assert (not (= v0 v2)))
(assert (not (= v1 v2)))
(assert (or (or (P v0) (P v1)) (P v2)))
(assert (or (or (= x0 v0) (= x0 v1)) (= x0 v2)))
(assert (or (or (= x1 v0) (= x1 v1)) (= x1 v2)))
(assert (or (or (= x2 v0) (= x2 v1)) (= x2 v2)))
(assert (or (or (= x3 v0) (= x3 v1)) (= x3 v2)))
(assert (or (or (= x4 v0) (= x4 v1)) (= x4 v2)))
(check-sat)
