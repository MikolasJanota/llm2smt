(set-info :smt-lib-version 2.6)
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-fun v0 () U)
(declare-fun v1 () U)
(declare-fun v2 () U)
(declare-fun f (U) U)
(assert (not (= v0 v1)))
(assert (not (= v0 v2)))
(assert (not (= v1 v2)))
(assert (or (or (= (f v0) v0) (= (f v0) v1)) (= (f v0) v2)))
(assert (or (or (= (f v1) v0) (= (f v1) v1)) (= (f v1) v2)))
(assert (or (or (= (f v2) v0) (= (f v2) v1)) (= (f v2) v2)))
(assert (= (f v0) v1))
(assert (= (f v1) v2))
(assert (= (f v2) v0))
(check-sat)
