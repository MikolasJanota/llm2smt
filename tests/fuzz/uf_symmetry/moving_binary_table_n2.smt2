(set-info :smt-lib-version 2.6)
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-fun v0 () U)
(declare-fun v1 () U)
(declare-fun op (U U) U)
(assert (not (= v0 v1)))
(assert (or (= (op v0 v0) v0) (= (op v0 v0) v1)))
(assert (or (= (op v0 v1) v0) (= (op v0 v1) v1)))
(assert (or (= (op v1 v0) v0) (= (op v1 v0) v1)))
(assert (or (= (op v1 v1) v0) (= (op v1 v1) v1)))
(assert (= (op v0 v0) v0))
(assert (= (op v0 v1) v1))
(assert (= (op v1 v0) v1))
(assert (= (op v1 v1) v0))
(check-sat)
