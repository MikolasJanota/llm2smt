(set-info :smt-lib-version 2.6)
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-fun v0 () U)
(declare-fun v1 () U)
(declare-fun x0 () U)
(declare-fun x1 () U)
(declare-fun x2 () U)
(declare-fun x3 () U)
(declare-fun x4 () U)
(declare-fun f (U) U)
(assert (not (= v0 v1)))
(assert (or (= x0 v0) (= x0 v1)))
(assert (or (= x1 v0) (= x1 v1)))
(assert (or (= x2 v0) (= x2 v1)))
(assert (or (= x3 v0) (= x3 v1)))
(assert (or (= x4 v0) (= x4 v1)))
(assert (or (= (f v0) v0) (= (f v0) v1)))
(assert (or (= (f v1) v0) (= (f v1) v1)))
(check-sat)
