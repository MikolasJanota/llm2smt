(set-info :smt-lib-version 2.6)
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-fun v0 () U)
(declare-fun v1 () U)
(declare-fun f (U) U)
(assert (not (= v0 v1)))
(assert (or (= (f v0) v0) (= (f v0) v1)))
(assert (or (= (f v1) v0) (= (f v1) v1)))
(assert (= (f v0) v1))
(assert (= (f v1) v0))
(check-sat)
