(set-logic QF_UF)
(declare-sort U 0)
(declare-fun c0 () U)
(declare-fun c1 () U)
(declare-fun c2 () U)
(declare-fun c3 () U)
(declare-fun p0 () Bool)
(declare-fun p1 () Bool)
(declare-fun f0 (U) U)
(declare-fun f1 (U) U)
(declare-fun g0 (U U) U)
(declare-fun b0 (Bool) U)
(declare-fun h0 (U U) Bool)
(assert (= (b0 (distinct c0 c2)) c3))
(assert (or (= c0 c1) (= c3 c2) (distinct c2 c1) (h0 c2 c1)))
(assert (= c2 (f0 (f0 c2))))
(assert (not (= (f0 (f0 c3)) (f0 (f0 c1)))))
(assert (not (= (b0 (distinct c1 c2 c1)) c3)))
(assert (= c1 (f1 c0)))
(check-sat)
