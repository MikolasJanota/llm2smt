(set-logic QF_UF)
(declare-sort U 0)
(declare-fun a () U)
(declare-fun b () U)
(declare-fun c () U)
(declare-fun d () U)
(declare-fun w () U)
(declare-fun x () U)
(declare-fun y () U)
(declare-fun z () U)
(assert (not (= a b)))
(assert (not (= c d)))
(assert (or (= w a) (= w b)))
(assert (or (= x a) (= x b)))
(assert (or (= y c) (= y d)))
(assert (or (= z c) (= z d)))
(check-sat)
