(set-logic QF_UF)
(declare-sort U 0)
(declare-fun c0 () U)
(declare-fun c1 () U)
(declare-fun c2 () U)
(declare-fun c3 () U)
(declare-fun f1 (U) U)
(declare-fun h0 (U U) Bool)
(assert (= (distinct c1 c0) (ite (distinct c2 c3 c2) (h0 c2 c3) (h0 c3 c0))))
(assert (= c2 c1))
(assert (= (ite (not (= c2 c1)) c3 c2) (f1 c2)))
(assert (ite (= c2 c0) (h0 c1 c3) (= c2 c3)))
(check-sat)
