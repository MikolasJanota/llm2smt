(set-logic QF_UF)
(declare-sort U 0)
(declare-fun c0 () U)
(declare-fun c1 () U)
(declare-fun c2 () U)
(declare-fun c3 () U)
(declare-fun p0 () Bool)
(declare-fun p1 () Bool)
(declare-fun f0 (U) U)
(declare-fun f1 (U) U)
(declare-fun g0 (U U) U)
(declare-fun t0 (U U U) U)
(declare-fun t1 (U U U) U)
(declare-fun b0 (Bool) U)
(declare-fun b1 (Bool) U)
(declare-fun h0 (U U) Bool)
(declare-fun h1 (U) Bool)
(declare-fun h2 (U) Bool)
; Regression: proof_fail_000064 with --preprocess-passes 1.
; The simplifier forces unit equalities (e.g. c1=(b1 p1), c3=(b1(h0 c2 c0)))
; as permanent CC equalities.  The EUF propagates these to SAT as unit literals,
; which then appear as premises in theory clauses.  Without the fix, the proof
; snapshot omitted these atoms (they were simplified to True), so bv_decide
; could not discharge the premises and failed with a spurious counterexample.
(assert (ite (=> (h0 c2 c0) (= c2 c1) (h1 c1)) (or (distinct c2 c3) (not p1)) (h0 c2 c3)))
(assert (= c0 c1 c3))
(assert (h0 c3 c0))
(assert (= c1 (b1 p1)))
(assert (not (= (f0 c3) (f0 c1))))
(assert (= (t1 c0 c0 c3) (g0 (g0 c2 c0) c3)))
(assert (distinct c3 c0))
(assert (= (t0 c3 (g0 c3 c1) c0) c3))
(assert (= c3 (b1 (h0 c2 c0))))
(assert (xor (xor p1 (= c3 c1)) (= c0 c3 c3)))
(check-sat)
