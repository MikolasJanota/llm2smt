(set-logic QF_UF)
(declare-sort U 0)
(declare-fun a () U)
(declare-fun b () U)
(declare-fun c () U)
(declare-fun x () U)
(declare-fun y () U)
(declare-fun z () U)
(declare-fun P (U) Bool)
(assert (not (= a b)))
(assert (not (= a c)))
(assert (not (= b c)))
(assert (or (P a) (P b) (P c)))
(assert (or (= x a) (= x b) (= x c)))
(assert (or (= y a) (= y b) (= y c)))
(assert (or (= z a) (= z b) (= z c)))
(check-sat)
