(set-logic QF_UF)
(declare-sort U 0)
(declare-fun a () U)
(declare-fun b () U)
(declare-fun c () U)
(declare-fun f (U) U)
(assert (not (= a b)))
(assert (not (= a c)))
(assert (not (= b c)))
(assert (or (= (f a) a) (= (f a) b) (= (f a) c)))
(assert (or (= (f b) a) (= (f b) b) (= (f b) c)))
(assert (or (= (f c) a) (= (f c) b) (= (f c) c)))
(check-sat)
